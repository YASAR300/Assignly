# =========================================================================
#                    ASSIGNLY APPLICATION ENVIRONMENT CONFIG
# =========================================================================

# ----------------- FLASK BACKEND CONFIG (.env) -----------------
# Connecting Flask SQLAlchemy to Supabase PostgreSQL database
DATABASE_URL=postgresql://postgres:[PASSWORD]@[REF].supabase.co:5432/postgres

# Secret key used for signing Flask cookies/sessions
SECRET_KEY=generate_a_secure_secret_key_here

# Supabase API JWT Secret used to locally decode Google Auth user tokens
SUPABASE_JWT_SECRET=your_supabase_project_jwt_secret_here

# Gmail SMTP configurations for automated task notifications
SMTP_USER=your_smtp_gmail_address@gmail.com
SMTP_PASSWORD=your_16_character_google_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Next.js frontend client URL (configured for CORS access)
FRONTEND_URL=http://localhost:3000


# ----------------- NEXT.JS FRONTEND CONFIG (.env.local) -----------------
# Public credentials connecting client browser to Supabase Auth provider
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR_PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# Endpoint pointing client API requests to the Flask Server
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000
